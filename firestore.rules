rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
  
    /* =========================
    	 🌍 PUBLIC READ — DONATION PAGES (Phase 13)
       ========================= */

    /* =========================
       🔑 CORE HELPERS
       ========================= */

    function isSignedIn() {
      return request.auth != null;
    }

    function hasUserDoc() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function userDoc() {
      return hasUserDoc()
        ? get(/databases/$(database)/documents/users/$(request.auth.uid))
        : null;
    }

    function userRole() {
      return hasUserDoc() ? userDoc().data.role : null;
    }

    function userOrgId() {
      return hasUserDoc() ? userDoc().data.orgId : null;
    }

    function isSuperAdmin() {
      return userRole() == "super-admin";
    }

    function isOrgAdmin() {
      return userRole() == "admin";
    }

    function isCoach() {
      return userRole() == "coach";
    }

    function isAthlete() {
      return userRole() == "athlete";
    }

    /**
     * 🔒 Core org gate
     * - Org members
     * - OR super-admin operating inside selected org
     */
    function canAccessOrg(orgId) {
      return isSignedIn() && (
        (hasUserDoc() && userOrgId() == orgId) ||
        isSuperAdmin()
      );
    }

    function isPrivilegedOrgReader() {
      return isOrgAdmin() || isSuperAdmin();
    }

    function coachHasTeam(teamId) {
      return isSignedIn()
        && isCoach()
        && hasUserDoc()
        && teamId is string
        && teamId != ""
        && (
          (("teamId" in userDoc().data) && userDoc().data.teamId == teamId) ||
          (("teamIds" in userDoc().data)
            && userDoc().data.teamIds is list
            && userDoc().data.teamIds.hasAny([teamId])) ||
          (("assignedTeamIds" in userDoc().data)
            && userDoc().data.assignedTeamIds is list
            && userDoc().data.assignedTeamIds.hasAny([teamId])) ||
          (
            exists(/databases/$(database)/documents/teams/$(teamId)) &&
            get(/databases/$(database)/documents/teams/$(teamId)).data.orgId == userOrgId() &&
            get(/databases/$(database)/documents/teams/$(teamId)).data.coachId == request.auth.uid
          )
        );
    }

    function coachAssignedTeamIds() {
      return !isSignedIn() || !isCoach() || !hasUserDoc()
        ? []
        : (
            (("assignedTeamIds" in userDoc().data)
              && userDoc().data.assignedTeamIds is list
              && userDoc().data.assignedTeamIds.size() > 0)
              ? userDoc().data.assignedTeamIds
              : (
                  (("teamIds" in userDoc().data)
                    && userDoc().data.teamIds is list
                    && userDoc().data.teamIds.size() > 0)
                    ? userDoc().data.teamIds
                    : (
                        (("teamId" in userDoc().data)
                          && userDoc().data.teamId is string
                          && userDoc().data.teamId != "")
                          ? [userDoc().data.teamId]
                          : []
                      )
                )
          );
    }

    function canCoachReadByTeam(orgId, teamId) {
      return isSignedIn()
        && isCoach()
        && userOrgId() == orgId
        && coachHasTeam(teamId);
    }

    function canCoachReadByCampaign(orgId, campaignId) {
      return isSignedIn()
        && isCoach()
        && userOrgId() == orgId
        && campaignId is string
        && campaignId != ""
        && exists(/databases/$(database)/documents/campaigns/$(campaignId))
        && (
          coachHasTeam(
            get(/databases/$(database)/documents/campaigns/$(campaignId)).data.teamId
          )
          || (
            ("teamIds" in get(/databases/$(database)/documents/campaigns/$(campaignId)).data)
            && get(/databases/$(database)/documents/campaigns/$(campaignId)).data.teamIds is list
            && get(/databases/$(database)/documents/campaigns/$(campaignId)).data.teamIds.hasAny(
              coachAssignedTeamIds()
            )
          )
        );
    }

    function canCoachReadByAthlete(orgId, athleteId) {
      return isSignedIn()
        && isCoach()
        && userOrgId() == orgId
        && athleteId is string
        && athleteId != ""
        && exists(/databases/$(database)/documents/athletes/$(athleteId))
        && coachHasTeam(
          get(/databases/$(database)/documents/athletes/$(athleteId)).data.teamId
        );
    }

    function canCoachReadScopedResource(resourceData) {
      return isSignedIn()
        && isCoach()
        && (
          (("teamId" in resourceData) && canCoachReadByTeam(resourceData.orgId, resourceData.teamId)) ||
          (("campaignId" in resourceData) && canCoachReadByCampaign(resourceData.orgId, resourceData.campaignId)) ||
          (("athleteId" in resourceData) && canCoachReadByAthlete(resourceData.orgId, resourceData.athleteId))
        );
    }

    function orgIdUnchanged() {
      return !("orgId" in resource.data) || request.resource.data.orgId == resource.data.orgId;
    }

    /* ===========================
       COACHES
       =========================== */
    match /coaches/{coachId} {
      allow read: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.orgId
           == resource.data.orgId
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
           in ["admin", "super-admin", "coach"];

      // Writes restricted to admins only
      allow create: if request.auth != null
        && request.resource.data.orgId is string
        && canAccessOrg(request.resource.data.orgId)
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
           in ["admin", "super-admin"];

      allow update: if request.auth != null
        && orgIdUnchanged()
        && canAccessOrg(resource.data.orgId)
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
           in ["admin", "super-admin"];

      allow delete: if request.auth != null
        && canAccessOrg(resource.data.orgId)
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
           in ["admin", "super-admin"];
    }

    /* =========================
       👤 USERS
       ========================= */
    match /users/{uid} {

      // ✅ READ (query-safe)
      allow read: if isSignedIn() && (
        request.auth.uid == uid ||
        ((isOrgAdmin() || isCoach() || isSuperAdmin())
          && canAccessOrg(resource.data.orgId))
      );

      // ✅ Allow self-creation ONCE (invite bootstrap)
      allow create: if request.auth != null
        && request.auth.uid == uid
        && request.resource.data.uid == uid
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.inviteId is string
        && exists(/databases/$(database)/documents/invites/$(request.resource.data.inviteId))
        && get(/databases/$(database)/documents/invites/$(request.resource.data.inviteId)).data.status == "pending"
        && get(/databases/$(database)/documents/invites/$(request.resource.data.inviteId)).data.email == request.auth.token.email
        && get(/databases/$(database)/documents/invites/$(request.resource.data.inviteId)).data.role == request.resource.data.role
        && get(/databases/$(database)/documents/invites/$(request.resource.data.inviteId)).data.orgId == request.resource.data.orgId
        && request.resource.data.role in ["admin", "coach", "athlete"]
        && request.resource.data.orgId is string;

      // ✅ User can update self (NO role/org escalation)
      allow update: if request.auth != null
        && request.auth.uid == uid
        && !("role" in request.resource.data)
        && !("orgId" in request.resource.data);

      // ✅ Admins can manage users
      allow update: if request.auth != null
        && (isOrgAdmin() || isSuperAdmin())
        && canAccessOrg(resource.data.orgId)
        && orgIdUnchanged();

      allow delete: if request.auth != null
        && (isOrgAdmin() || isSuperAdmin())
        && canAccessOrg(resource.data.orgId);
    }

    /* =========================
       🏢 ORGANIZATIONS
       ========================= */
    match /organizations/{orgId} {
      allow read: if isSignedIn() && (
        userOrgId() == orgId || isSuperAdmin()
      );

      // Admins and super-admins may create organization records.
      allow create: if isSignedIn()
        && (isOrgAdmin() || isSuperAdmin());

      allow update: if isSignedIn()
        && (isOrgAdmin() || isCoach() || isSuperAdmin())
        && canAccessOrg(orgId)
        && request.resource.data.diff(resource.data).changedKeys()
          .hasOnly([
            "donorInviteTemplate",
            "donorInviteTemplates",
              "donorInviteSubjects",
              "orgTimeZone",
              "dripGlobalEnabled",
              "dripStartedAt",
              "reporting",
              "updatedAt"
            ]);

      allow write: if isSuperAdmin();
    }

    /* =========================
       🧑‍🤝‍🧑 TEAMS
       ========================= */
    match /teams/{teamId} {

      // Org admins/super-admins see all; coaches only assigned teams
      allow read: if isSignedIn()
        && (
          (isPrivilegedOrgReader() && canAccessOrg(resource.data.orgId))
          || canCoachReadByTeam(resource.data.orgId, teamId)
        );

      // Athlete can read their own team (ALL fields, including invite code)
      allow read: if isSignedIn()
        && exists(/databases/$(database)/documents/athletes/$(request.auth.uid))
        && get(/databases/$(database)/documents/athletes/$(request.auth.uid)).data.teamId == teamId;

      // Admin / coach can manage team
      allow create: if isSignedIn()
        && (isOrgAdmin() || isCoach() || isSuperAdmin())
        && canAccessOrg(request.resource.data.orgId);

      allow update: if isSignedIn()
        && (isOrgAdmin() || isCoach() || isSuperAdmin())
        && canAccessOrg(resource.data.orgId)
        && orgIdUnchanged();

      allow delete: if isSignedIn()
        && (isOrgAdmin() || isSuperAdmin())
        && canAccessOrg(resource.data.orgId);
    }

    /* =========================
       🏃 ATHLETES
       ========================= */
    match /athletes/{athleteId} {
    
    	allow create: if request.auth != null
        && request.auth.uid == athleteId
        && exists(/databases/$(database)/documents/invites/$(request.resource.data.inviteId))
        && get(/databases/$(database)/documents/invites/$(request.resource.data.inviteId)).data.status == "pending"
        && get(/databases/$(database)/documents/invites/$(request.resource.data.inviteId)).data.email == request.auth.token.email;

      // ✅ Any signed-in user may read athlete docs
      // ✅ Public read when athlete is tied to a public campaign
      allow read: if (isSignedIn()
          && (
            (isPrivilegedOrgReader() && canAccessOrg(resource.data.orgId))
            || canCoachReadByTeam(resource.data.orgId, resource.data.teamId)
            || canCoachReadByCampaign(resource.data.orgId, resource.data.campaignId)
            || request.auth.uid == athleteId
          ))
        || (resource.data.campaignId is string
            && get(/databases/$(database)/documents/campaigns/$(resource.data.campaignId)).data.isPublic == true);

      // ✅ Only org admins, coaches, or super-admins may create/update
      allow create: if isSignedIn()
        && (isOrgAdmin() || isCoach() || isSuperAdmin())
        && canAccessOrg(request.resource.data.orgId);

      allow update: if isSignedIn()
        && (isOrgAdmin() || isCoach() || isSuperAdmin())
        && canAccessOrg(resource.data.orgId)
        && orgIdUnchanged();

      // ✅ Athlete can update their own invite message (no other fields)
      allow update: if isSignedIn()
        && request.auth.uid == athleteId
        && canAccessOrg(resource.data.orgId)
        && request.resource.data.diff(resource.data).changedKeys()
          .hasOnly([
            "inviteMessage",
            "donorInviteTemplate",
            "donorInviteTemplates",
            "drip",
            "updatedAt"
          ]);
    }
    
    /* =========================
   		 🔗 TEAM ATHLETES
       ========================= */
    match /teamAthletes/{docId} {

      // Org admins/super-admins see all; coaches only assigned teams
      allow read: if isSignedIn()
        && (
          (isPrivilegedOrgReader() && canAccessOrg(resource.data.orgId))
          || canCoachReadByTeam(resource.data.orgId, resource.data.teamId)
        );

      // Athlete can read records for their own team
      allow read: if isSignedIn()
        && exists(/databases/$(database)/documents/athletes/$(request.auth.uid))
        && get(/databases/$(database)/documents/athletes/$(request.auth.uid)).data.teamId == resource.data.teamId;

      allow create: if isSignedIn()
        && (isOrgAdmin() || isCoach() || isSuperAdmin())
        && canAccessOrg(request.resource.data.orgId);

      allow update: if isSignedIn()
        && (isOrgAdmin() || isCoach() || isSuperAdmin())
        && canAccessOrg(resource.data.orgId)
        && orgIdUnchanged();

      allow delete: if isSignedIn()
        && (isOrgAdmin() || isCoach() || isSuperAdmin())
        && canAccessOrg(resource.data.orgId);
    }

    /* =========================
       📣 CAMPAIGNS
       ========================= */
    match /campaigns/{campaignId} {

      // ✅ Any signed-in user can read campaigns
      // ✅ Public campaigns readable by anyone
      // 🔐 Org / team isolation enforced by queries, not rules
      allow read: if resource.data.isPublic == true
        || (isSignedIn()
          && (
            (isPrivilegedOrgReader() && canAccessOrg(resource.data.orgId))
            || canCoachReadByTeam(resource.data.orgId, resource.data.teamId)
            || (
              isCoach()
              && userOrgId() == resource.data.orgId
              && ("teamIds" in resource.data)
              && resource.data.teamIds is list
              && resource.data.teamIds.hasAny(coachAssignedTeamIds())
            )
          ));

      // ✅ Only admins & super-admins may write
      allow create: if isSignedIn()
        && (isOrgAdmin() || isSuperAdmin())
        && canAccessOrg(request.resource.data.orgId);

      allow update: if isSignedIn()
        && (isOrgAdmin() || isSuperAdmin())
        && canAccessOrg(resource.data.orgId)
        && orgIdUnchanged();

      allow delete: if isSignedIn()
        && (isOrgAdmin() || isSuperAdmin())
        && canAccessOrg(resource.data.orgId);
    }

    match /campaigns/{campaignId}/comments/{commentId} {
      allow read: if get(/databases/$(database)/documents/campaigns/$(campaignId)).data.isPublic == true;
      allow write: if false;
    }

    match /campaigns/{campaignId}/public_donors/{donorId} {
      allow read: if get(/databases/$(database)/documents/campaigns/$(campaignId)).data.isPublic == true;
      allow write: if false;
    }
    
    /* =========================
       🔗 CAMPAIGN ATHLETES
       ========================= */
    match /campaignAthletes/{docId} {

      allow read: if isSignedIn()
        && (
          (isPrivilegedOrgReader() && canAccessOrg(resource.data.orgId))
          || canCoachReadByTeam(resource.data.orgId, resource.data.teamId)
        );

      allow read: if isSignedIn()
        && exists(/databases/$(database)/documents/athletes/$(request.auth.uid))
        && get(/databases/$(database)/documents/athletes/$(request.auth.uid)).data.teamId == resource.data.teamId;

      allow create: if isSignedIn()
        && (isOrgAdmin() || isCoach() || isSuperAdmin())
        && canAccessOrg(request.resource.data.orgId);

      allow update: if isSignedIn()
        && (isOrgAdmin() || isCoach() || isSuperAdmin())
        && canAccessOrg(resource.data.orgId)
        && orgIdUnchanged();

      allow delete: if isSignedIn()
        && (isOrgAdmin() || isCoach() || isSuperAdmin())
        && canAccessOrg(resource.data.orgId);
    }

    /* =========================
       💳 DONATIONS
       ========================= */
    match /donations/{donationId} {

      // ✅ Admin/super-admin org scope
      // ✅ Coach team/campaign/athlete scope
      // ✅ Athlete can read own donations
      allow read: if isSignedIn()
        && resource.data != null
        && (
          (isPrivilegedOrgReader() && canAccessOrg(resource.data.orgId))
          || canCoachReadScopedResource(resource.data)
          || request.auth.uid == resource.data.athleteId
        );

      // ✅ Public receipt access by document ID (paid only)
      allow get: if resource.data != null && resource.data.status == "paid";

      // ✅ Stripe webhook creates donations (Admin SDK bypasses rules)
      allow create: if false;

      // ❌ No client-side updates
      allow update, delete: if false;
    }

    /* =========================
       💖 DONORS (Org-scoped)
       ========================= */
    match /donors/{donorId} {
      allow read: if isSignedIn()
        && resource.data != null
        && (
          (isPrivilegedOrgReader() && canAccessOrg(resource.data.orgId))
          || canCoachReadScopedResource(resource.data)
        );

      allow create: if isSignedIn()
        && request.resource.data.orgId is string
        && canAccessOrg(request.resource.data.orgId);

      allow update: if isSignedIn()
        && resource.data != null
        && (
          (isPrivilegedOrgReader() && canAccessOrg(resource.data.orgId))
          || canCoachReadScopedResource(resource.data)
        )
        && orgIdUnchanged();

      allow delete: if isSignedIn()
        && resource.data != null
        && (
          (isPrivilegedOrgReader() && canAccessOrg(resource.data.orgId))
          || canCoachReadScopedResource(resource.data)
        );
    }

    /* =========================
       👥 ATHLETE CONTACTS (PRIVATE)
       ========================= */
    match /athlete_contacts/{contactId} {
      allow read: if isSignedIn()
        && canAccessOrg(resource.data.orgId)
        && (isOrgAdmin() || isCoach() || request.auth.uid == resource.data.athleteId);

      allow create: if isSignedIn()
        && request.resource.data.orgId is string
        && canAccessOrg(request.resource.data.orgId)
        && request.resource.data.athleteId is string
        && (isOrgAdmin() || isCoach() || request.auth.uid == request.resource.data.athleteId);

      allow update: if isSignedIn()
        && canAccessOrg(resource.data.orgId)
        && (isOrgAdmin() || isCoach() || request.auth.uid == resource.data.athleteId)
        && orgIdUnchanged();

      allow delete: if isSignedIn()
        && canAccessOrg(resource.data.orgId)
        && (isOrgAdmin() || isCoach() || request.auth.uid == resource.data.athleteId);
    }

    /* =========================
       ✉️ MESSAGES (ORG LOG)
       ========================= */
    match /messages/{messageId} {
      allow read: if isSignedIn()
        && resource.data != null
        && (
          (isPrivilegedOrgReader() && canAccessOrg(resource.data.orgId))
          || canCoachReadScopedResource(resource.data)
          || request.auth.uid == resource.data.athleteId
        );

      allow create: if isSignedIn()
        && request.resource.data.orgId is string
        && canAccessOrg(request.resource.data.orgId);

      allow update, delete: if false;
    }
    
    /* =========================
       📊 DONATION ROLLUPS (ADMIN / COACH READ)
       ========================= */
    match /donation_rollups/{rollupId} {

      // Org admins and super-admins can read rollups
      allow read: if isSignedIn()
        && resource.data != null
        && isPrivilegedOrgReader()
        && canAccessOrg(resource.data.orgId);

      // ❌ No client-side writes (scheduled function only)
      allow write: if false;
    }

    /* =========================
       📩 INVITES
       ========================= */
    match /invites/{inviteId} {

      // Anyone can read a pending invite (link open)
      // Donor invites are not publicly readable
      allow read: if resource.data.status == "pending"
        && resource.data.role != "donor";

      // Invited user can read their invite
      allow read: if isSignedIn()
        && request.auth.token.email == resource.data.email;

      // Invited user can accept invite
      allow update: if isSignedIn()
        && resource.data.status == "pending"
        && request.resource.data.status == "accepted"
        && request.resource.data.acceptedAt is timestamp
        && request.auth.token.email == resource.data.email
        && orgIdUnchanged();

      // Admins can read invites in their org
      allow read: if isSignedIn()
        && (isOrgAdmin() || isSuperAdmin())
        && canAccessOrg(resource.data.orgId);

      // Admins and coaches can create coach/athlete/admin invites in their org
      allow create: if isSignedIn()
        && (isOrgAdmin() || isCoach() || isSuperAdmin())
        && canAccessOrg(request.resource.data.orgId);

      // Athletes/coaches/admins can create donor invites
      allow create: if isSignedIn()
        && request.resource.data.role == "donor"
        && request.resource.data.type == "donor_invite"
        && canAccessOrg(request.resource.data.orgId)
        && request.resource.data.campaignId is string
        && request.resource.data.athleteId is string
        && (isAthlete() || isCoach() || isOrgAdmin() || isSuperAdmin());

      // Admins can delete invites
      allow delete: if isSignedIn()
        && (isOrgAdmin() || isSuperAdmin())
        && canAccessOrg(resource.data.orgId);
    }

            /* =========================
		  	 📬 OUTBOUND MAIL (Mailgun / Email Extension)
			   ========================= */
		match /mail/{mailId} {
  		allow create: if false;
		}
  }
}
